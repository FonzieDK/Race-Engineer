{
  "name": "race-engineer",
  "productName": "Race-Engineer",
  "version": "1.1.0",
  "description": "Race-Engineer desktop app for iRacing telemetry",
  "author": "InfiNxt",
  "main": "electron/main.js",
  "scripts": {
    "test": "python -m unittest discover -s tests -p \"test_*.py\" && node --test tests/*.js",
    "start": "electron .",
    "electron": "electron .",
    "package": "electron-forge package --platform win32 --arch x64",
    "make": "electron-forge make --platform win32 --arch x64",
    "make:msi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-msi.ps1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-wix": "^7.11.2",
    "electron": "^43.1.1"
  }
}
